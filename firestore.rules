rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Pairing codes - allow anyone to create/read (needed for watch pairing)
    match /pairing_codes/{code} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    // Device tokens - allow anyone to create/read (for watch auto-login)
    // Never expires, deleted only when user signs out
    match /device_tokens/{token} {
      allow create: if true;
      allow read: if true;
      allow delete: if true;
    }
    
    // SpellCheck Party — allow anyone to create and read rooms, host controls updates
    match /rooms/{roomId} {
      allow create: if true;
      allow read: if true;
      allow update: if request.resource.data.diff() == {field: 'state'} ||
                       request.resource.data.diff() == {field: 'currentWord'} ||
                       request.resource.data.diff() == {field: 'roundStartTime'} ||
                       request.resource.data.diff() == {field: 'difficulty'} ||
                       request.resource.data.diff() == {field: 'winScore'} ||
                       request.resource.data.diff() == {field: 'roundDelay'} ||
                       request.resource.data.diff().size() > 0;
      allow delete: if true;

      match /players/{playerId} {
        allow read: if true;
        allow write: if true;
        allow delete: if true;
      }
      match /answers/{docId} {
        allow read, write: if true;
      }
      match /results/{docId} {
        allow read, write: if true;
      }
    }
  }
}